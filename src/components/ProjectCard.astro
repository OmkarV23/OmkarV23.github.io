---
interface Props {
  title: string;
  body: string;
  type: string;
  image?: string;
  slug?: string;
}

const { title, body, type, image = "/images/placeholder-project.jpg", slug } = Astro.props;
const description = (body.split('## Overview')[1]?.split('##')[0]?.trim() || body.split('\n')[0])
  .split('\n')
  .filter(line => line.trim() !== '')  // Remove empty lines
  .slice(0, 3)  // Take first 3 non-empty lines
  .join('\n')
  .slice(0, 300) + '...'; // Limit to 300 characters and add ellipsis
---

<div class="bg-white rounded-lg shadow-sm overflow-hidden">
  <div class="aspect-video bg-gray-100">
    <img src={image} alt={title} class="w-full h-full object-cover" />
  </div>
  <div class="p-6">
    <span class="text-primary text-sm font-medium">{type}</span>
    <h3 class="text-xl font-semibold mt-2 mb-3">{title}</h3>
    <div class="prose prose-sm text-gray-600 mb-4">
      <p style="display: -webkit-box; -webkit-line-clamp: 5; -webkit-box-orient: vertical; overflow: hidden;">{description}</p>
    </div>
    {slug && (
      <a href={`/projects/${slug}`} class="text-primary hover:text-primary-dark font-medium">
        View Details →
      </a>
    )}
  </div>
</div>
