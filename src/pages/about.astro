<Layout title="About - Omkar Shailendra Vengurlekar">
  <main class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-12">About Me</h1>
      
      <!-- <div class="prose max-w-none mb-16">
        <p class="text-lg text-gray-600 mb-6">
          I am currently a Ph.D. student at Arizona State University, specializing in Computer Vision, Machine Learning, and Computational Photography within the Imaging Lyceum Lab, under the guidance of Dr. Suren Jayasuriya. My research is focused on developing advanced deep learning models for dynamic scene restoration, particularly addressing the challenges posed by atmospheric turbulence in Ultra-Zoom and astrophotography applications.
        </p>
        <p class="text-lg text-gray-600">
          Prior to my Ph.D., I completed an M.S. at the NeuroPhotonics Lab, GIST in South Korea under Professor Euiheon Chung. My research focused on deep learning-based automated assessment of infrared eyelid images and reflection removal using GANs.
        </p>
      </div> -->

      <h2 class="text-3xl font-bold mb-8">Education</h2>
      <div class="space-y-8 mb-16">
        {education.map((edu) => (
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <h3 class="text-xl font-semibold text-primary">{edu.school}</h3>
            <p class="text-lg font-medium mt-2">{edu.degree}</p>
            <p class="text-gray-500 mt-1">{edu.period}</p>
            {edu.supervisor && (
              <p class="text-gray-600 mt-2 italic">{edu.supervisor}</p>
            )}
            <ul class="mt-4 space-y-2">
              {edu.details.map((detail) => (
                <li class="text-gray-600">• {detail}</li>
              ))}
            </ul>
            {edu.courses && (
              <div class="mt-6">
                <h4 class="text-lg font-semibold mb-3">Relevant Courses</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                  {edu.courses.map((course) => (
                    <div class="bg-gray-50 p-2 rounded">
                      <span class="font-medium text-primary">{course.code}</span>
                      <span class="mx-2">-</span>
                      <span class="text-gray-700">{course.name}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

