                      <span class="ml-4">{detail}</span>
                    ) : (
                      <>
                        <span class="text-gray-400 mr-2">•</span>
                        <span>{detail}</span>
                      </>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div> -->
    </div>
  </main>
</Layout>