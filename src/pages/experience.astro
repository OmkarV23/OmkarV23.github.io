---

<Layout title="Experience - Omkar Shailendra Vengurlekar">
  <main class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold mb-12">Professional Experience</h1>
      
      <div class="space-y-8 mb-16">
        {professionalExperiences.map((exp) => (
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="flex justify-between items-start mb-4">
              <div>
                <h3 class="text-xl font-semibold text-primary">{exp.company}</h3>
                <p class="text-lg font-medium mt-1">{exp.position}</p>
                <p class="text-gray-500">{exp.location}</p>
              </div>
              <p class="text-gray-500">{exp.period}</p>
            </div>
            <ul class="mt-4 space-y-2">
              {exp.details.map((detail) => (
                <li class="text-gray-600 flex items-start">
                  <span class="text-primary mr-2">•</span>
                  <span>{detail}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- <div class="bg-gray-50 p-8 rounded-lg mb-16">
        <h2 class="text-2xl font-semibold mb-8 text-gray-700">Teaching Experience</h2>
