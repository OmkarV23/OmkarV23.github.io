---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - Omkar Shailendra Vengurlekar">
  <main class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl font-bold mb-4">Contact</h1>
        <p class="text-gray-600 max-w-2xl mx-auto">I am open to discussing research collaborations and new opportunities in Computer Graphics, Computer Vision and Deep Learning.</p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-12">
        <div class="bg-white p-8 rounded-xl shadow-sm">
          <h2 class="text-2xl font-semibold mb-6">Current Location</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-medium text-gray-900 mb-2">Office Address</h3>
              <p class="text-gray-600">
                Arizona State University<br />
                Imaging Lyceum Lab<br />
                University Graduate Building<br />
                945 S Mill Ave<br />
                Tempe, AZ 85281
              </p>
            </div>
            <div>
              <h3 class="font-medium text-gray-900 mb-2">Contact Details</h3>
              <p class="text-gray-600">
                <span class="block mb-1">📧 ovengurl@asu.edu</span>
                <!-- <span class="block">📱 623-283-0227</span> -->
              </p>
            </div>
            <div>
              <h3 class="font-medium text-gray-900 mb-2">Office Hours</h3>
              <p class="text-gray-600">
                Monday - Friday<br />
                9:00 AM - 5:00 PM MST
              </p>
            </div>
          </div>
        </div>
        
        <div class="bg-white p-8 rounded-xl shadow-sm">
          <h2 class="text-2xl font-semibold mb-6">Academic Affiliations</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-medium text-gray-900 mb-2">Current Role</h3>
              <p class="text-gray-600">
                PhD Candidate<br />
                School of Electrical, Computer and Energy Engineering<br />
                Arizona State University
              </p>
            </div>
            <div>
              <h3 class="font-medium text-gray-900 mb-2">Lab Memberships</h3>
              <p class="text-gray-600">
                Imaging Lyceum Lab<br />
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
